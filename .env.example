# URL de la API de tu instancia Traccar
TRACCAR_URL=<TRACCAR_URL>
TRACCAR_USERNAME=<TRACCAR_USERNAME>
TRACCAR_PASSWORD=<TRACCAR_PASSWORD>

# PostgreSQL Configuration localhost
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_HOST=<POSTGRES_HOST>
POSTGRES_PORT=<POSTGRES_PORT>
POSTGRES_ENTERPRISE=<POSTGRES_ENTERPRISE>

# El prefijo para las bases de datos de cada empresa (ej: enterprise_1)
POSTGRES_ENTERPRISE_PREFIX=<POSTGRES_ENTERPRISE_PREFIX>

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_SECRET=<JWT_SECRET>
